        "font_weight": "bold",
        "text_align": "center",
        "color": "#000000"
      }
    },
    {
      "id": "cover-divider",
      "type": "line",
      "x": 55,
      "y": 130,
      "z_index": 1,
      "visible": true,
      "name": "Garis Pemisah",
      "direction": "horizontal",
      "length": 100,
      "thickness": 1,
      "color": "#000000"
    },
    {
      "id": "cover-meta",
      "type": "text",
      "x": 55,
      "y": 140,
      "z_index": 1,
      "visible": true,
      "name": "Info Dokumen",
