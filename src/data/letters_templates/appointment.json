      "height": 40,
      "fit": "contain"
    },
    {
      "id": "cover-company",
      "type": "text",
      "x": 55,
      "y": 75,
      "z_index": 1,
      "visible": true,
      "name": "Nama Perusahaan",
      "content": { "type": "static", "value": "PT AGSYA KARYA MANCA" },
      "max_width": 100,
      "style": {
        "font_family": "Times New Roman",
        "font_size": 14,
        "font_weight": "bold",
        "text_align": "center",
        "color": "#000000"
      }
    },
    {
      "id": "cover-title",
      "type": "text",
      "x": 55,
      "y": 110,
      "z_index": 1,
      "visible": true,
      "name": "Judul Surat",
      "content": { "type": "static", "value": "SURAT PENUNJUKAN" },
      "max_width": 100,
      "style": {
        "font_family": "Times New Roman",
