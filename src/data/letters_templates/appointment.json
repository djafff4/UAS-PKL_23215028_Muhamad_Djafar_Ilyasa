      "source": { "type": "static", "url": "/assets/logo/logo_akman.png" },
      "width": 28,
      "height": 28,
      "fit": "contain"
    },
    {
      "id": "header-divider",
      "type": "line",
      "x": 20,
      "y": 58,
      "z_index": 1,
      "visible": true,
      "name": "Garis Kop Surat",
      "direction": "horizontal",
      "length": 170,
      "thickness": 2,
      "color": "#1e40af"
    },
    {
      "id": "doc-title",
      "type": "text",
      "x": 20,
      "y": 65,
      "z_index": 1,
      "visible": true,
      "name": "Judul Dokumen",
      "content": { "type": "static", "value": "SURAT PENUNJUKAN" },
      "max_width": 170,
      "style": {
        "font_family": "Times New Roman",
        "font_size": 13,
        "font_weight": "bold",
        "text_align": "center",
        "color": "#000000",
        "text_decoration": "underline"
      }
    },
    {
      "id": "signature-pihak1",
      "type": "signature",
      "x": 30,
      "y": 230,
      "z_index": 1,
      "visible": true,
      "name": "Tanda Tangan Pihak 1",
      "signature_type": "wet",
      "label": "PIHAK PERTAMA",
      "name": "Direktur Utama",
      "title": "PT Agsya Karya Manca",
      "width": 60,
      "height": 40
    },
    {
      "id": "signature-pihak2",
      "type": "signature",
      "x": 120,
      "y": 230,
      "z_index": 1,
      "visible": true,
      "name": "Tanda Tangan Pihak 2",
      "signature_type": "wet",
      "label": "PIHAK KEDUA",
      "name": "{{ staff_name }}",
      "title": "{{ position }}",
      "width": 60,
      "height": 40
    }
  ],
  "bindings": [
    { "key": "letter_number", "label": "Nomor Surat", "source": "letter", "value_type": "string", "required": true, "example_value": "SP-2026-001" },
    { "key": "staff_name", "label": "Nama Karyawan", "source": "staff", "value_type": "string", "required": true, "path": "profile.full_name", "example_value": "John Doe" },
    { "key": "position", "label": "Jabatan", "source": "staff", "value_type": "string", "path": "profile.position", "example_value": "Staff IT" },
    { "key": "department", "label": "Departemen", "source": "staff", "value_type": "string", "path": "profile.department", "example_value": "IT Department" },
    { "key": "company_address", "label": "Alamat Perusahaan", "source": "company", "value_type": "string", "example_value": "Jl. Contoh No. 123, Semarang" },
    { "key": "appointment_type", "label": "Jenis Penunjukan", "source": "letter", "value_type": "string", "example_value": "PENUNJUKAN" },
    { "key": "effective_date", "label": "Tanggal Efektif", "source": "letter", "value_type": "date", "date_format": "DD MMMM YYYY", "example_value": "01 Januari 2026" },
    { "key": "end_date", "label": "Tanggal Berakhir", "source": "letter", "value_type": "date", "date_format": "DD MMMM YYYY", "example_value": "31 Desember 2026" },
    { "key": "reports_to", "label": "Melapor Ke", "source": "letter", "value_type": "string", "example_value": "Direktur Utama" },
    { "key": "status", "label": "Status", "source": "letter", "value_type": "string", "example_value": "ACTIVE" },
    { "key": "created_at", "label": "Tanggal Dibuat", "source": "letter", "value_type": "date", "date_format": "DD MMMM YYYY", "example_value": "17 Juni 2026" }
  ],
  "default_bindings": [
    { "key": "company_address", "value": "Jl. Contoh No. 123, Semarang" },
    { "key": "status", "value": "DRAFT" }
  ],
  "metadata": {
    "created_by": "system",
